PORT=4000
NODE_ENV=development

# Local docker-compose mongo (matches docker-compose.yml at the repo root)
MONGODB_URI=mongodb://ttm:ttmpass@localhost:27017/team_task_manager?authSource=admin

# For production use a MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/team_task_manager?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173
